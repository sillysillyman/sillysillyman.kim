# Notion API (get from https://www.notion.so/profile/integrations)
NOTION_API_KEY=your_notion_api_key

# Notion database ID (extract from your Notion DB URL)
NOTION_DATABASE_ID=your_database_id

# Site URL (your deploy domain)
SITE_URL=https://yourdomain.com

# Giscus comments (get from https://giscus.app, comments disabled if unset)
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
